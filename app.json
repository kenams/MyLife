{
  "expo": {
    "name": "MyLife",
    "slug": "mylife",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#07111f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "mylife",
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111f"
      },
      "package": "com.kenams.mylife"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
